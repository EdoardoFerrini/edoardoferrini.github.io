---
/**
 * Steps — Scheletro di base (Reset 2.0)
 */
---

<ol class="steps-list">
  <slot />
</ol>

<style>
  /* Reset totale - Ripartiamo da qui */
  .steps-list {
    counter-reset: steps;
    list-style: none;
    padding: 0;
    margin: 2.5rem 0;
  }

  .steps-list :global(li) {
    counter-increment: steps;
    position: relative;
    padding-left: 3rem;   /* Spazio fisso per i numeri */
    padding-bottom: 2rem; /* Spazio tra gli step */
  }

  /* Cerchio Numerato */
  .steps-list :global(li::before) {
    content: counter(steps);
    position: absolute;
    left: 0;
    top: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--bg-dim);
    border: 2px solid var(--accent);
    color: var(--accent);
    font-size: 13px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  /* Linea di collegamento verticale */
  .steps-list :global(li:not(:last-child)::after) {
    content: '';
    position: absolute;
    left: 13px; /* Centro esatto del cerchio da 28px - 1px di raggio linea */
    top: 28px;
    bottom: 0;
    width: 2px;
    background: var(--border);
    opacity: 0.3;
    z-index: 1;
  }

  /* Reset margini per i figli (es. paragrafi MDX) */
  .steps-list :global(li > *) {
    margin: 0;
  }

  .steps-list :global(li p) {
    line-height: 1.6;
    color: var(--fg-dim);
  }

  .steps-list :global(li strong) {
    color: var(--fg);
    display: inline-block;
    margin-bottom: 0.25rem;
  }

  .steps-list :global(li code) {
    background: var(--highlight);
    color: var(--accent);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

</style>
