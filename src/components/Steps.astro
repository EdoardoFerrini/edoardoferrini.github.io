---
/**
 * Steps — numbered step list for tutorials.
 * 
 * Usage in MDX:
 *   <Steps>
 *     <li>Install the package</li>
 *     <li>Configure the settings</li>
 *     <li>Run the command</li>
 *   </Steps>
 */
---

<ol class="steps-list">
  <slot />
</ol>

<style>
  .steps-list {
    counter-reset: steps;
    list-style: none;
    padding: 0;
    margin: 1.75rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .steps-list :global(li) {
    counter-increment: steps;
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.75rem;
    align-items: start;
  }

  .steps-list :global(li::before) {
    content: counter(steps);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--highlight);
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Nested content in steps */
  .steps-list :global(li > p:last-child) { margin-bottom: 0; }
  .steps-list :global(li > code) {
    background: var(--code-bg);
    color: var(--tertiary);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.875em;
  }
</style>
