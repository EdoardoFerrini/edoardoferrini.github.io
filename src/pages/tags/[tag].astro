---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  const tagMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }

  return [...tagMap.entries()].map(([tagName, tagPosts]) => ({
    params: { tag: tagName },
    props: { 
      tag: tagName, 
      posts: tagPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;

// Calcoliamo allTags qui per sicurezza, evitando problemi di prop-drilling/serialization
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const tagMapCount = new Map<string, number>();
for (const p of allPosts) {
  for (const t of p.data.tags) {
    tagMapCount.set(t, (tagMapCount.get(t) ?? 0) + 1);
  }
}
const allTags = [...tagMapCount.entries()].sort((a, b) => b[1] - a[1]);

function formatDate(date: Date) {
  return date.toLocaleDateString('it-IT', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout title={`#${tag} — edoardo ferrini`}>
  <a href="/tags" class="back-link">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    Tutti i tag
  </a>
  <div class="page-header">
    <h1>#{tag}</h1>
    <p>{posts.length} {posts.length === 1 ? 'articolo' : 'articoli'}</p>
  </div>

  <div class="tag-navigation">
    <ul class="tag-list">
      {allTags.map(([t, count]) => (
        <li>
          <a href={`/tags/${t}`} class={`tag-chip ${t === tag ? 'active' : ''}`}>
            #{t}
            <span class="count">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <ul class="post-list-minimal">
    {posts.map((post) => (
      <li class="post-item-minimal">
        <time class="post-date-minimal" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        <a href={`/posts/${post.id}`} class="post-title-minimal">
          {post.data.title}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
