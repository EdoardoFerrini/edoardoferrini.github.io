---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cerca — edoardo ferrini" description="Cerca contenuti nel blog e nel keyboard garden.">
  <div class="search-page-container">
    <header class="search-header">
      <h1>Cerca</h1>
      <p>Cerca articoli, tag e contenuti nel blog.</p>
    </header>

    <div id="search" class="search-wrapper"></div>
    
    <div class="search-page-footer">
      <span>Premi <kbd>↵</kbd> per selezionare</span>
      <span>Premi <kbd>↑↓</kbd> per navigare</span>
    </div>
  </div>
</BaseLayout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<script>
  import { PagefindUI } from '@pagefind/default-ui';

  function initPagefind() {
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      resetStyles: false,
      translations: {
        placeholder: 'Cerca contenuti...',
      },
      autofocus: true,
    });

    // Ensure focus after initialization
    setTimeout(() => {
      const input = document.querySelector('.pagefind-ui__search-input');
      if (input) (input as HTMLInputElement).focus();
    }, 100);
  }

  // Support Astro view transitions
  document.addEventListener('astro:page-load', initPagefind);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPagefind);
  } else {
    initPagefind();
  }
</script>

<style is:global>
  /* Pagefind variables */
  :root {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--highlight);
    --pagefind-ui-font: 'IBM Plex Mono', monospace;
  }

  .search-page-container {
    max-width: 800px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .search-header {
    margin-bottom: 3rem;
  }

  .search-header h1 {
    margin-top: 0;
    font-size: 2.5rem;
  }

  .search-header p {
    color: var(--fg-dim);
    font-size: 1.1rem;
  }

  .search-wrapper {
    min-height: 400px;
  }

  .search-page-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    display: flex;
    gap: 2rem;
    font-size: 13px;
    color: var(--fg-dim);
  }

  .search-page-footer kbd {
    background: var(--lightgray);
    color: var(--darkgray);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: inherit;
    font-weight: 600;
    margin-right: 4px;
  }

  .search-error {
    text-align: center;
    padding: 3rem;
    background: var(--highlight);
    border-radius: 8px;
    color: var(--accent);
  }

  /* Pagefind UI Overrides */
  .pagefind-ui,
  .pagefind-ui * {
    font-family: 'IBM Plex Mono', monospace !important;
  }

  .pagefind-ui__search-input {
    background: var(--bg-alt) !important;
    border-radius: 8px !important;
    font-size: 1.2rem !important;
    padding: 1rem 1.25rem !important;
    color: var(--fg) !important;
    border: none !important;
  }

  .pagefind-ui__search-input:focus {
    border-color: var(--accent) !important;
    outline: none !important;
    box-shadow: 0 0 0 2px var(--highlight) !important;
  }

  .pagefind-ui__result {
    padding: 1.5rem 0 !important;
  }

  .pagefind-ui__result-link {
    color: var(--accent) !important;
    font-size: 1.2rem !important;
    font-weight: 600 !important;
    text-decoration: none !important;
  }

  .pagefind-ui__result-link:hover {
    text-decoration: underline !important;
  }

  .pagefind-ui__result-excerpt {
    color: var(--fg-dim) !important;
    margin-top: 0.5rem !important;
    line-height: 1.6 !important;
  }

  .pagefind-ui__message {
    font-size: 1rem !important;
    color: var(--fg-dim) !important;
    margin-bottom: 2rem !important;
  }
</style>
