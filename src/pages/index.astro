---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

// Build tag cloud from all posts
const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="edoardo ferrini — Build To Understand" description="Blog di Edoardo Ferrini: programmazione, knowledge management e fotografia.">

  <!-- RSS / Stay Updated Card -->
  <section class="card">
    <div class="card-header">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      <h3>Stay Updated</h3>
    </div>
    <div class="card-content">
      <p>Ricevi aggiornamenti quando pubblico nuovi contenuti. No spam, solo bit.</p>
      <a href="/rss.xml" class="card-action">Iscriviti via RSS →</a>
    </div>
  </section>

  <!-- Bio / Intro section — inspired by alexop.dev -->
  <div class="home-bio">
    <p class="home-bio-text">
      Sono uno sviluppatore appassionato di tecnologia e knowledge sharing. Questo blog ha due scopi: condividere quello che imparo e affinare le mie capacità.
    </p>
    <p class="home-bio-text">
      Trovi tre tipi di contenuto qui: <strong>post</strong>, approfondimenti curati su argomenti che ho esplorato a fondo, <strong>note</strong> per internalizzare nuovi concetti, e il mio <a href="https://edoardoferrini.github.io/brain/">digital garden</a> per esplorazioni più libere e connesse.
    </p>
    <p class="home-bio-text bio-sign">
      Se qualcosa ti interessa, scrivimi — il feedback costruttivo è sempre benvenuto.<br/>
      — Edoardo
    </p>
  </div>

  <!-- Recent posts -->
  <section class="home-section">
    <div class="section-header">
      <h2>Ultimi Post</h2>
      <a href="/posts" class="view-all">Tutti i post →</a>
    </div>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/posts/${post.id}`} class="post-item-title">{post.data.title}</a>
          <span class="post-date">{formatDate(post.data.date)}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- Tags Card -->
  {tags.length > 0 && (
    <section class="card">
      <div class="card-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        <h3>Explore Tags</h3>
      </div>
      <div class="card-content">
        <ul class="tag-cloud">
          {tags.map(([tag, count]) => (
            <li>
              <a href={`/tags/${tag}`} class="tag-cloud-item">
                <span class="tag-cloud-name">{tag}</span>
                <span class="tag-cloud-count">({count})</span>
              </a>
            </li>
          ))}
        </ul>
        <div style="margin-top: 1.5rem;">
          <a href="/tags" class="card-action">Tutti i tag →</a>
        </div>
      </div>
    </section>
  )}

</BaseLayout>
