---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('it-IT', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout title="Posts — edoardo ferrini" description="Tutti gli articoli del blog di Edoardo Ferrini.">

  <div class="page-header">
    <h1>Posts</h1>
    <p>{posts.length} {posts.length === 1 ? 'articolo' : 'articoli'}</p>
  </div>

  <ul class="post-list-minimal">
    {posts.map((post) => (
      <li class="post-item-minimal">
        <time class="post-date-minimal" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        <a href={`/posts/${post.id}`} class="post-title-minimal">
          {post.data.title}
        </a>
      </li>
    ))}
  </ul>

</BaseLayout>
