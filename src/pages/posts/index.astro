---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('it-IT', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout title="Posts — edoardo ferrini" description="Tutti gli articoli del blog di Edoardo Ferrini.">

  <div class="page-header">
    <h1>Posts</h1>
    <p>{posts.length} {posts.length === 1 ? 'articolo' : 'articoli'}</p>
  </div>

  <ul class="post-grid">
    {posts.map((post) => (
      <li class="post-card-wrapper">
        <article class="post-card">
          {post.data.heroImage && (
            <a href={`/posts/${post.id}`} class="post-card-image">
              <img 
                src={post.data.heroImage} 
                alt={post.data.title} 
                loading="lazy"
              />
            </a>
          )}
          <div class="post-card-content">
            <div class="post-card-meta">
              <span>{formatDate(post.data.date)}</span>
              {post.data.tags && post.data.tags.length > 0 && (
                <>
                  <span> • </span>
                  <span>{post.data.tags[0]}</span>
                </>
              )}
            </div>
            <a href={`/posts/${post.id}`} class="post-card-title">
              {post.data.title}
            </a>
            {post.data.description && (
              <p class="post-card-description">{post.data.description}</p>
            )}
            <div class="post-card-footer">
              Leggi di più →
            </div>
          </div>
        </article>
      </li>
    ))}
  </ul>

</BaseLayout>
