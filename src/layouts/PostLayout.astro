---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, tags = [], headings } = Astro.props;

const formattedDate = date.toLocaleDateString('it-IT', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — edoardo ferrini`} description={description}>
  <ReadingProgress />
  <a href="/posts" class="back-link">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    Tutti i post
  </a>
  <article class="prose">
    <h1>{title}</h1>
    <div class="post-meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <a href={`/tags/${tag}`} class="post-tag">{tag}</a>
          ))}
        </div>
      )}
    </div>
    {description && <p class="post-lead">{description}</p>}
    <TableOfContents headings={headings} />
    <slot />
  </article>
  <Giscus />
</BaseLayout>
