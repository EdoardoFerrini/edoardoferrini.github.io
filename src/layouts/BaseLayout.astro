---
import '../styles/global.css';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Il blog di Edoardo Ferrini' } = Astro.props;
const currentPath = Astro.url.pathname;

// Nav: logo brings home, Posts/About are internal, Brain links out to Quartz
const navLinks = [
  {
    href: '/posts',
    label: 'Posts',
    external: false,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    href: '/tags',
    label: 'Tags',
    external: false,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
  },
  {
    href: 'https://edoardoferrini.github.io/brain/',
    label: 'Brain',
    external: false,
    svg: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>`,
  },
  {
    href: '/about',
    label: 'About',
    external: false,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  },
];

// Active check: /posts matches /posts and /posts/any-slug
function isActive(href: string, path: string, external: boolean) {
  if (external) return false;
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- IBM Plex Mono — same as Quartz config typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
    <!-- Anti-flash: apply saved theme before paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.setAttribute('saved-theme', theme);
      })();
    </script>
  </head>
  <body>
    <!-- ════════════════════════════════
         HEADER — mirrors Quartz .page-header
         ════════════════════════════════ -->
    <header>
      <nav class="nav-inner" aria-label="Navigazione principale">

        <!-- Logo: site name -->
        <a href="/" class="brain-logo" aria-label="Home">
          <svg class="blog-logo-icon" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
  <rect width="20" height="16" x="2" y="4" rx="2"/>
  <path d="M6 9l4 3-4 3"/>
  <path d="M13 15h4"/>
</svg>
          <span class="site-logo-text">edoardoferrini.dev</span>
        </a>

        <!-- Nav links — mirrors LinksHeader.tsx -->
        <div class="links-header">
          {navLinks.map(({ href, label, svg }) => (
            <a
              href={href}
              class="nav-item-link"
              aria-current={isActive(href, currentPath, false) ? 'page' : undefined}
            >
              <span class="nav-item-icon" set:html={svg} aria-hidden="true" />
              <span class="nav-item-label">{label}</span>
            </a>
          ))}
        </div>

        <!-- Spacer -->
        <div class="nav-spacer" aria-hidden="true"></div>

        <!-- Right: Search & Dark mode toggle -->
        <div class="nav-right">
          <Search />
          <!-- Darkmode button — mirrors Quartz Darkmode.tsx -->
          <button id="theme-toggle" class="darkmode" aria-label="Cambia tema">
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18"
              fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18"
              fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>

      </nav>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <!-- Footer — mirrors Quartz Footer.tsx structure -->
    <footer>
      <div class="container">
        <div class="footer-inner">
          <span>© {new Date().getFullYear()} Edoardo Ferrini</span>
          <div class="footer-links">
            <a href="https://edoardoferrini.github.io/brain/">Second Brain</a>
            <a href="/posts">Posts</a>
            <a href="/tags">Tags</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle')!;
      const iconSun = document.getElementById('icon-sun')!;
      const iconMoon = document.getElementById('icon-moon')!;
      const root = document.documentElement;

      function updateIcons() {
        const isDark = root.getAttribute('data-theme') !== 'light';
        iconSun.style.display = isDark ? 'block' : 'none';
        iconMoon.style.display = isDark ? 'none' : 'block';
      }

      updateIcons();

      toggle.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        root.setAttribute('data-theme', next);
        root.setAttribute('saved-theme', next);
        localStorage.setItem('theme', next);
        updateIcons();
      });

      // Global Search Shortcut (⌘K)
      window.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          window.location.href = '/search';
        }
      });
    </script>
  </body>
</html>