---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Il mio blog personale' } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/posts', label: 'Posts' },
  { href: '/tags', label: 'Tags' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- IBM Plex Mono — font usato per tutto nel tuo quartz.config.ts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <!-- Anti-flash: applica tema salvato prima del paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <header>
      <div class="container">
        <nav class="nav-inner" aria-label="Navigazione principale">

          <!-- Logo -->
          <a href="/" class="nav-logo">
             <img
              src="/avatar.svg"
              alt="Edoardo Ferrini"
              class="navbar-avatar"
              width="36"
              height="36"
            />
          </a>

          <!-- Link navigazione -->
          <ul class="nav-links">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={currentPath.startsWith(href) ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>

          <!-- Destra: Search + Toggle tema -->
          <div class="nav-right">
            <button class="search-btn" aria-label="Cerca" title="Cerca (Ctrl+K)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <span>Cerca</span>
              <span class="search-shortcut">Ctrl+K</span>
            </button>

            <button id="theme-toggle" aria-label="Cambia tema">
              <!-- Sole: visibile in dark mode -->
              <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
              <!-- Luna: visibile in light mode -->
              <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </button>
          </div>

        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer>
      <div class="container">
        <div class="footer-inner">
          <span>© {new Date().getFullYear()} Edoardo Ferrini</span>
          <div class="footer-links">
            <a href="https://edoardoferrini.github.io/brain/" target="_blank" rel="noopener">Digital Garden</a>
            <a href="/rss.xml">RSS</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle')!;
      const iconSun = document.getElementById('icon-sun')!;
      const iconMoon = document.getElementById('icon-moon')!;
      const root = document.documentElement;

      function updateIcons() {
        const isDark = root.getAttribute('data-theme') !== 'light';
        iconSun.style.display = isDark ? 'block' : 'none';
        iconMoon.style.display = isDark ? 'none' : 'block';
      }

      updateIcons();

      toggle.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        root.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateIcons();
      });
    </script>
  </body>
</html>
